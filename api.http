### Health check
GET http://localhost:3000/health HTTP/1.1

### 1. Registro

POST {{baseUrl}}/user/register HTTP/1.1
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "Test1234!"
}

### 2. Validar email

PUT {{baseUrl}}/user/validation HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "685811"
}

### 3. Login

POST {{baseUrl}}/user/login HTTP/1.1
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "NuevaClave5678!"
}

### 4a. Onboarding — datos personales

PUT {{baseUrl}}/user/register HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Juan",
  "lastName": "García",
  "nif": "12345678A"
}

### 4b. Onboarding — datos de compañía

PATCH {{baseUrl}}/user/company HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "isFreelance": false,
  "name": "Alpedrete Construcciones",
  "cif": "B12345678",
  "address": {
    "street": "Calle Mayor",
    "number": "1",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 5. Obtener usuario

GET {{baseUrl}}/user HTTP/1.1
Authorization: Bearer {{token}}

### 6. Refresh token

POST {{baseUrl}}/user/refresh HTTP/1.1
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### 7. Logout

POST {{baseUrl}}/user/logout HTTP/1.1
Authorization: Bearer {{token}}

### 8. Cambiar contraseña

PUT {{baseUrl}}/user/password HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "currentPassword": "Test1234!",
  "newPassword": "NuevaClave5678!"
}

### 9. Invitar compañero (solo admin)

POST {{baseUrl}}/user/invite HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "companero@example.com",
  "name": "María",
  "lastName": "López"
}

### 10. Eliminar usuario

DELETE {{baseUrl}}/user?soft=true HTTP/1.1
Authorization: Bearer {{token}}